{
  "name": "@boaideas/ui-kit",
  "version": "1.4.3",
  "description": "A Vue 3 UI components library with Reka UI and Tailwind CSS",
  "type": "module",
  "main": "./build/ui-kit.js",
  "types": "./types/index.d.ts",
  "publishConfig": {
    "access": "restricted"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./build/ui-kit.js"
    },
    "./style.css": "./build/style.css",
    "./tailwind.preset": "./tailwind.preset.js"
  },
  "files": [
    "build",
    "types",
    "tailwind.preset.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,js,json,css}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:watch": "vite build --watch"
  },
  "keywords": [
    "vue",
    "vue3",
    "ui-kit",
    "components",
    "button",
    "dialog",
    "tooltip",
    "dropdown",
    "reka-ui",
    "tailwindcss",
    "headless-ui",
    "design-system",
    "accessible",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0 || >=20.0.0 || >=22.0.0",
    "npm": ">=8.0.0"
  },
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "10.2.15",
    "@storybook/vue3-vite": "10.2.15",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/ui": "^4.0.14",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.22",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^27.2.0",
    "minimatch": "^10.2.3",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "reka-ui": "^2.0.0",
    "rollup": "^4.59.0",
    "sass": "^1.97.3",
    "storybook": "10.2.15",
    "tailwindcss": "^3.4.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.14",
    "vue": "^3.5.24",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.4"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.5.0"
  }
}
