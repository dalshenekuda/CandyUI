{
  "name": "@dalshenekuda/candy-ui",
  "version": "1.4.3",
  "description": "A React UI components library with Tailwind CSS",
  "type": "module",
  "main": "./build/ui-kit.js",
  "types": "./types/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./build/ui-kit.js"
    },
    "./style.css": "./build/style.css",
    "./tailwind.preset": "./tailwind.preset.js"
  },
  "files": [
    "build",
    "types",
    "tailwind.preset.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,css}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build:watch": "vite build --watch",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "keywords": [
    "react",
    "ui-kit",
    "components",
    "button",
    "dialog",
    "tailwindcss",
    "design-system",
    "accessible",
    "typescript"
  ],
  "engines": {
    "node": ">=18.0.0 || >=20.0.0 || >=22.0.0",
    "npm": ">=8.0.0"
  },
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.0.14",
    "autoprefixer": "^10.4.22",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.0",
    "jsdom": "^27.2.0",
    "minimatch": "^10.2.3",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "rollup": "^4.59.0",
    "sass": "^1.99.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^3.4.18",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.5.0"
  }
}
